                "relation_delta": -0.2,
                "intention_shift": "Resist Player's Authority",
                "min_response": "You think you can intimidate ME? Wrong move.",
                "max_response": "Bold. I respect that. But respect isn't enough.",
                "scripted": false
              }
            ]
          },
          {
            "choice_id": "manipulative_approach",
            "text": "Look, we both know the Insurgency needs allies. I have skills you need. Let's not waste time with tests.",
            "language_art": "manipulative",
            "authority_tone": 0.4,
            "diplomacy_tone": 0.5,
            "empathy_tone": 0.1,
            "manipulation_tone": 0.9,
            "ideology_alignment": "Pragmatism",
            "requirements": {
              "min_manipulation": 6
