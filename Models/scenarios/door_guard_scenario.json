      "choices": [
        {
          "choice_id": "empathetic_approach",
          "text": "I've seen what's happened to this land. People are suffering. I want to help make things right.",
          "language_art": "empathetic",
          "authority_tone": 0.2,
          "diplomacy_tone": 0.4,
          "empathy_tone": 0.8,
          "manipulation_tone": 0.1,
          "ideology_alignment": "Communitarianism",
