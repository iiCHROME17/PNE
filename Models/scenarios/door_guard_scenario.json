          "authority_tone": 0.4,
          "diplomacy_tone": 0.5,
          "empathy_tone": 0.1,
          "manipulation_tone": 0.9,
          "ideology_alignment": "Pragmatism",
          "interaction_outcomes": [
            {
              "outcome_id": "suspicious_evaluation",
              "stance_delta": { "cognitive.self_esteem": -0.05 },
              "relation_delta": -0.1,
              "intention_shift": "Scrutinize Player's Motives",
              "min_response": "Everyone thinks they're clever. What makes you different?",
              "max_response": "Skills, huh? Maybe. But I've seen too many smooth talkers.",
              "scripted": false
            }
          ],
          "terminal_outcomes": []
        },
        {
          "choice_id": "diplomatic_reasoning",
          "text": "I understand your caution. Let me explain why our goals align and how we can help each other.",
          "language_art": "diplomatic",
          "authority_tone": 0.3,
          "diplomacy_tone": 0.9,
          "empathy_tone": 0.4,
          "manipulation_tone": 0.2,
          "ideology_alignment": "Utilitarianism",
          "interaction_outcomes": [
            {
              "outcome_id": "consider_alliance",
              "stance_delta": { "cognitive.cog_flexibility": 0.05 },
              "relation_delta": 0.1,
              "intention_shift": "Consider Strategic Partnership",
              "min_response": "Mutual benefit? Everyone says that until it costs them something.",
              "max_response": "You're thinking strategically. I appreciate that. Keep talking.",
              "scripted": false
            }
          ],
          "terminal_outcomes": []
        }
      ]
    },

