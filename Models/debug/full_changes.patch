+        return DialogueContext(
+            player_skills=filter_ctx.player_skills,
+            player_relation=filter_ctx.player_relation,
+            npc_self_esteem=filter_ctx.npc_self_esteem,
+            npc_emotional_valence=filter_ctx.npc_emotional_valence,
