-
-    @property
-    def turn_count(self) -> int:
-        return self.processor.conversation.turn_count
-
-    def add_exchange(
-        self,
-        speaker: str,
-        text: str,
-        metadata: Optional[Dict[str, Any]] = None,
-    ) -> None:
