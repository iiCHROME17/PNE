+    /** pdoc search index */const docs = {"version": "0.9.5", "fields": ["qualname", "fullname", "annotation", "default_value", "signature", "bases", "doc"], "ref": "fullname", "documentStore": {"docs": {"narrative_engine": {"fullname": "narrative_engine", "modulename": "narrative_engine", "kind": "module", "doc": "<p>Psychological Narrative Engine - Multi-NPC Conversation Engine</p>\n\n<p>A Fallout-style psychological narrative engine where:</p>\n\n<ul>\n<li>Player choices are visible and structured (node/choice tree)</li>\n<li>NPC responses are generated via the BDI+LLM pipeline</li>\n<li>Scenarios are NPC-agnostic; NPC individuality is injected at runtime</li>\n<li>Multiple NPCs can participate independently in the same scenario</li>\n<li>Routing between nodes is DYNAMIC: driven by NPC BDI state + player_relation</li>\n</ul>\n\n<p>Author: Jerome Bawa (original), refactor by AI assistant</p>\n"}, "narrative_engine.NarrativeEngine": {"fullname": "narrative_engine.NarrativeEngine", "modulename": "narrative_engine", "qualname": "NarrativeEngine", "kind": "class", "doc": "<p>High-level orchestrator for Fallout-style conversations using pne's BDI engine.</p>\n\n<p>Key difference from traditional choice-based systems:</p>\n\n<ul>\n<li>Choices no longer have next_node hardcoded</li>\n<li>After a choice is processed, each NPC's state is evaluated against\nthe CURRENT node's transitions to determine where that NPC goes next</li>\n<li>Different NPCs can end up on different nodes after the same player choice</li>\n</ul>\n\n<p>Workflow:</p>\n\n<ol>\n<li>Load NPCs (personality, beliefs, world state)</li>\n<li>Load scenario (nodes, choices, transitions - NPC-agnostic)</li>\n<li>Start session (inject NPCs into scenario)</li>\n<li>Process player choices:\n<ul>\n<li>Parse choice into PlayerDialogueInput</li>\n<li>Run through each NPC's DialogueProcessor (BDI + LLM)</li>\n<li>Evaluate transitions against each NPC's updated state</li>\n<li>Route each NPC to appropriate next node</li>\n</ul></li>\n<li>Export rich conversation logs</li>\n</ol>\n\n<p>Attributes:\n    use_ollama: Whether to use Ollama for LLM generation\n    ollama_url: URL for Ollama API endpoint\n    scenarios: Dict of loaded scenarios (scenario_id -> scenario data)\n    npcs: Dict of loaded NPCs (npc_id -> NPCModel)\n    sessions: Dict of active conversation sessions (session_id -> ConversationSession)</p>\n"}, "narrative_engine.NarrativeEngine.__init__": {"fullname": "narrative_engine.NarrativeEngine.__init__", "modulename": "narrative_engine", "qualname": "NarrativeEngine.__init__", "kind": "function", "doc": "<p>Initialize the narrative engine.</p>\n\n<p>Args:\n    use_ollama: Whether to use Ollama for LLM-based response generation\n    ollama_url: URL of the Ollama API endpoint</p>\n", "signature": "<span class=\"signature pdoc-code condensed\">(<span class=\"param\"><span class=\"n\">use_ollama</span><span class=\"p\">:</span> <span class=\"nb\">bool</span> <span class=\"o\">=</span> <span class=\"kc\">True</span>, </span><span class=\"param\"><span class=\"n\">ollama_url</span><span class=\"p\">:</span> <span class=\"nb\">str</span> <span class=\"o\">=</span> <span class=\"s1\">&#39;http://localhost:11434&#39;</span></span>)</span>"}, "narrative_engine.NarrativeEngine.use_ollama": {"fullname": "narrative_engine.NarrativeEngine.use_ollama", "modulename": "narrative_engine", "qualname": "NarrativeEngine.use_ollama", "kind": "variable", "doc": "<p></p>\n"}, "narrative_engine.NarrativeEngine.ollama_url": {"fullname": "narrative_engine.NarrativeEngine.ollama_url", "modulename": "narrative_engine", "qualname": "NarrativeEngine.ollama_url", "kind": "variable", "doc": "<p></p>\n"}, "narrative_engine.NarrativeEngine.scenarios": {"fullname": "narrative_engine.NarrativeEngine.scenarios", "modulename": "narrative_engine", "qualname": "NarrativeEngine.scenarios", "kind": "variable", "doc": "<p></p>\n", "annotation": ": Dict[str, Dict[str, Any]]"}, "narrative_engine.NarrativeEngine.npcs": {"fullname": "narrative_engine.NarrativeEngine.npcs", "modulename": "narrative_engine", "qualname": "NarrativeEngine.npcs", "kind": "variable", "doc": "<p></p>\n", "annotation": ": Dict[str, PNE_Models.NPCModel]"}, "narrative_engine.NarrativeEngine.sessions": {"fullname": "narrative_engine.NarrativeEngine.sessions", "modulename": "narrative_engine", "qualname": "NarrativeEngine.sessions", "kind": "variable", "doc": "<p></p>\n", "annotation": ": Dict[str, narrative_engine.session.ConversationSession]"}, "narrative_engine.NarrativeEngine.load_npc": {"fullname": "narrative_engine.NarrativeEngine.load_npc", "modulename": "narrative_engine", "qualname": "NarrativeEngine.load_npc", "kind": "function", "doc": "<p>Load an NPC from a JSON file.</p>\n\n<p>Args:\n    filepath: Path to the NPC JSON file\n    npc_id: Optional custom ID for the NPC (defaults to lowercase name)</p>\n\n<p>Returns:\n    The NPC ID that was assigned</p>\n\n<p>Raises:\n    FileNotFoundError: If the NPC file doesn't exist</p>\n", "signature": "<span class=\"signature pdoc-code condensed\">(<span class=\"param\"><span class=\"bp\">self</span>, </span><span class=\"param\"><span class=\"n\">filepath</span><span class=\"p\">:</span> <span class=\"nb\">str</span>, </span><span class=\"param\"><span class=\"n\">npc_id</span><span class=\"p\">:</span> <span class=\"n\">Optional</span><span class=\"p\">[</span><span class=\"nb\">str</span><span class=\"p\">]</span> <span class=\"o\">=</span> <span class=\"kc\">None</span></span><span class=\"return-annotation\">) -> <span class=\"nb\">str</span>:</span></span>", "funcdef": "def"}, "narrative_engine.NarrativeEngine.load_scenario": {"fullname": "narrative_engine.NarrativeEngine.load_scenario", "modulename": "narrative_engine", "qualname": "NarrativeEngine.load_scenario", "kind": "function", "doc": "<p>Load a scenario from a JSON file.</p>\n\n<p>Args:\n    filepath: Path to the scenario JSON file\n    scenario_id: Optional custom ID (defaults to scenario's 