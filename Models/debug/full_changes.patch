+    @staticmethod
+    def _weighted_d6(bias: float) -> List[float]:
+        """6-element probability list for a d6 weighted toward high faces when bias is high.
+
+        bias=0 → uniform; bias=1 → heavily weighted toward 6.
+        Uses P(face k) ∝ exp(bias * k) for k=1..6.
+        """
