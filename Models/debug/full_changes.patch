+            <div class="pdoc-code codehilite"><pre><span></span><span id="ConversationSession-117"><a href="#ConversationSession-117"><span class="linenos">117</span></a><span class="nd">@dataclass</span>
+</span><span id="ConversationSession-118"><a href="#ConversationSession-118"><span class="linenos">118</span></a><span class="k">class</span><span class="w"> </span><span class="nc">ConversationSession</span><span class="p">:</span>
+</span><span id="ConversationSession-119"><a href="#ConversationSession-119"><span class="linenos">119</span></a><span class="w">    </span><span class="sd">&quot;&quot;&quot;</span>
+</span><span id="ConversationSession-120"><a href="#ConversationSession-120"><span class="linenos">120</span></a><span class="sd">    A running conversation session for a single scenario and one or more NPCs.</span>
+</span><span id="ConversationSession-121"><a href="#ConversationSession-121"><span class="linenos">121</span></a>
+</span><span id="ConversationSession-122"><a href="#ConversationSession-122"><span class="linenos">122</span></a><span class="sd">    The session manages:</span>
+</span><span id="ConversationSession-123"><a href="#ConversationSession-123"><span class="linenos">123</span></a><span class="sd">    - Scenario structure (NPC-agnostic nodes, choices, transitions)</span>
+</span><span id="ConversationSession-124"><a href="#ConversationSession-124"><span class="linenos">124</span></a><span class="sd">    - Multiple NPC states (each with independent BDI processing)</span>
+</span><span id="ConversationSession-125"><a href="#ConversationSession-125"><span class="linenos">125</span></a><span class="sd">    - Shared player choice log (visible conversation history)</span>
+</span><span id="ConversationSession-126"><a href="#ConversationSession-126"><span class="linenos">126</span></a>
+</span><span id="ConversationSession-127"><a href="#ConversationSession-127"><span class="linenos">127</span></a><span class="sd">    Key Design:</span>
+</span><span id="ConversationSession-128"><a href="#ConversationSession-128"><span class="linenos">128</span></a><span class="sd">    - Scenario is NPC-agnostic (same structure for any NPC)</span>
+</span><span id="ConversationSession-129"><a href="#ConversationSession-129"><span class="linenos">129</span></a><span class="sd">    - Each NPC has its own BDI/LLM pipeline and memory</span>
+</span><span id="ConversationSession-130"><a href="#ConversationSession-130"><span class="linenos">130</span></a><span class="sd">    - Player choices are shared across all NPCs</span>
+</span><span id="ConversationSession-131"><a href="#ConversationSession-131"><span class="linenos">131</span></a><span class="sd">    - Routing is resolved per-NPC via TransitionResolver</span>
+</span><span id="ConversationSession-132"><a href="#ConversationSession-132"><span class="linenos">132</span></a><span class="sd">    - Different NPCs can diverge to different nodes after same player choice</span>
+</span><span id="ConversationSession-133"><a href="#ConversationSession-133"><span class="linenos">133</span></a>
+</span><span id="ConversationSession-134"><a href="#ConversationSession-134"><span class="linenos">134</span></a><span class="sd">    Attributes:</span>
+</span><span id="ConversationSession-135"><a href="#ConversationSession-135"><span class="linenos">135</span></a><span class="sd">        scenario_id: Unique identifier for the scenario</span>
+</span><span id="ConversationSession-136"><a href="#ConversationSession-136"><span class="linenos">136</span></a><span class="sd">        scenario: Complete scenario data structure</span>
+</span><span id="ConversationSession-137"><a href="#ConversationSession-137"><span class="linenos">137</span></a><span class="sd">        npc_states: Dict mapping npc_id to NPCConversationState</span>
+</span><span id="ConversationSession-138"><a href="#ConversationSession-138"><span class="linenos">138</span></a><span class="sd">        player_choice_log: Global log of player choices (independent of NPC internals)</span>
+</span><span id="ConversationSession-139"><a href="#ConversationSession-139"><span class="linenos">139</span></a><span class="sd">    &quot;&quot;&quot;</span>
+</span><span id="ConversationSession-140"><a href="#ConversationSession-140"><span class="linenos">140</span></a>
+</span><span id="ConversationSession-141"><a href="#ConversationSession-141"><span class="linenos">141</span></a>    <span class="n">scenario_id</span><span class="p">:</span> <span class="nb">str</span>
+</span><span id="ConversationSession-142"><a href="#ConversationSession-142"><span class="linenos">142</span></a>    <span class="n">scenario</span><span class="p">:</span> <span class="n">Dict</span><span class="p">[</span><span class="nb">str</span><span class="p">,</span> <span class="n">Any</span><span class="p">]</span>
+</span><span id="ConversationSession-143"><a href="#ConversationSession-143"><span class="linenos">143</span></a>    <span class="n">npc_states</span><span class="p">:</span> <span class="n">Dict</span><span class="p">[</span><span class="nb">str</span><span class="p">,</span> <span class="n">NPCConversationState</span><span class="p">]</span>  <span class="c1"># npc_id -&gt; state</span>
+</span><span id="ConversationSession-144"><a href="#ConversationSession-144"><span class="linenos">144</span></a>
+</span><span id="ConversationSession-145"><a href="#ConversationSession-145"><span class="linenos">145</span></a>    <span class="c1"># Global visible choice history (independent of NPC internals)</span>
+</span><span id="ConversationSession-146"><a href="#ConversationSession-146"><span class="linenos">146</span></a>    <span class="n">player_choice_log</span><span class="p">:</span> <span class="n">List</span><span class="p">[</span><span class="n">Dict</span><span class="p">[</span><span class="nb">str</span><span class="p">,</span> <span class="n">Any</span><span class="p">]]</span> <span class="o">=</span> <span class="n">field</span><span class="p">(</span><span class="n">default_factory</span><span class="o">=</span><span class="nb">list</span><span class="p">)</span>
