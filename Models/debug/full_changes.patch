-            "turn": self.turn_count,
-            "speaker": speaker,
-            "text": text,
-        }
-        if metadata:
-            entry["metadata"] = metadata
-        self.history.append(entry)
-
-
-# ============================================================================
-# MULTI-NPC SESSION CONTAINER
-# ============================================================================
-
-
-@dataclass
-class ConversationSession:
