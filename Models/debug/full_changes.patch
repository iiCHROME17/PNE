-
-
-# ============================================================================
-# NARRATIVE ENGINE (MODULAR, MULTI-NPC, DYNAMIC ROUTING)
-# ============================================================================
-
-
-class NarrativeEngine:
-    """
-    High-level orchestrator for Fallout-style conversations using pne's BDI engine.
