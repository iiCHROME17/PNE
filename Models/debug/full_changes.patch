+                generated = result.get("response", "").strip()
+                if generated:
+                    return generated
+        except Exception as e:
+            print(f"[Ollama Error: {str(e)}]")
+
+        # Fallback to calibration range or empty
+        return min_r or max_r or ""
+
+    def generate_terminal(
+        self,
+        npc,
