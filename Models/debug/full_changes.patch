+
+        dot = sum(dict1.get(k, 0.0) * dict2.get(k, 0.0) for k in keys)
+        norm1 = math.sqrt(sum(v ** 2 for v in dict1.values()))
+        norm2 = math.sqrt(sum(v ** 2 for v in dict2.values()))
+
+        if norm1 == 0.0 or norm2 == 0.0:
+            return 0.0
+
+        return dot / (norm1 * norm2)
+
