+    .btn-danger:hover { background:#991b1b; }
+
+    .tab-btn { padding:0.45rem 1.25rem; font-size:0.875rem; cursor:pointer; border:1px solid #3b2d6e; border-bottom:none; color:#7c6b99; background:#12101f; border-radius:0.5rem 0.5rem 0 0; transition:background 0.1s; }
+    .tab-btn.active { background:#1e1b2e; color:#c084fc; font-weight:600; }
+
+    .chip { display:inline-flex; align-items:center; gap:4px; background:#3b0764; color:#e9d5ff; border-radius:9999px; padding:2px 10px; font-size:0.75rem; }
+    .chip button { background:none; border:none; color:#c084fc; cursor:pointer; font-size:1rem; line-height:1; padding:0; }
+    .chip button:hover { color:#fff; }
+
+    .check-item { display:flex; align-items:flex-start; gap:7px; background:#120f22; border:1px solid #2d2050; border-radius:0.4rem; padding:6px 9px; cursor:pointer; }
+    .check-item:hover { border-color:#7c3aed; }
+    .check-item.selected { border-color:#7c3aed; background:#1a1040; }
+    .check-item input[type=checkbox] { margin-top:2px; accent-color:#7c3aed; cursor:pointer; flex-shrink:0; }
+
+    .kv-row { display:flex; gap:6px; align-items:center; margin-bottom:5px; }
+
+    #json-preview { background:#0f0f1a; color:#a78bfa; font-family:monospace; font-size:0.74rem; border-radius:0; padding:1rem; max-height:560px; overflow-y:auto; white-space:pre; }
+
+    .world-badge { font-size:0.72rem; padding:3px 10px; border-radius:9999px; font-weight:600; white-space:nowrap; }
