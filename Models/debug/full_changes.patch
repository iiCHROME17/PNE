+    .hint { color:#7c6b99; font-size:0.7rem; }
+
+    .slider-row { display:flex; align-items:center; gap:10px; }
+    .slider-row input[type=range] { flex:1; }
+    .val-badge { background:#2d1f5e; color:#a78bfa; border-radius:4px; padding:1px 7px; font-size:0.8rem; font-family:monospace; min-width:3rem; text-align:center; }
+
+    .btn-primary { background:#7c3aed; color:#fff; border:none; border-radius:0.45rem; padding:0.5rem 1.1rem; font-size:0.875rem; font-weight:600; cursor:pointer; }
+    .btn-primary:hover { background:#6d28d9; }
